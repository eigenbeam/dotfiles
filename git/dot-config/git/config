[user]
	name = Kevin W. Beam
	email = kevin.beam@colorado.edu
[color]
	ui = auto
[apply]
	whitespace = nowarn
[core]
	autocrlf = input
	safecrlf = false
	pager = delta
	excludesFile = ~/.config/git/ignore
	# Uncomment to use global hooks (overrides per-repo hooks):
	# hooksPath = ~/.config/git/hooks
[alias]
	st = status
	sts = status --short
	hist = log --pretty=format:\"%h %ad | %s%d [%an]\" --graph --date=short
	co = checkout
	br = branch
	ci = commit
	unstage = restore --staged
	amend = commit --amend --no-edit
	undo = reset --soft HEAD~1
	prev = switch -
[push]
	default = upstream
	followTags = true
[pull]
	rebase = true
[fetch]
	prune = true
[rebase]
	autoStash = true
	autoSquash = true
[rerere]
	enabled = true
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
[credential]
	helper = osxkeychain
[github]
	user = eigenbeam
[interactive]
	diffFilter = delta --color-only
[delta]
	navigate = true
	side-by-side = true
	line-numbers = true
	syntax-theme = base16
	light = true
	minus-style = syntax "#d4b8b0"
	minus-emph-style = syntax "#c8a090"
	plus-style = syntax "#b8c4a8"
	plus-emph-style = syntax "#a8b898"
[diff]
	colorMoved = default
[merge]
	conflictStyle = zdiff3
[init]
	defaultBranch = main

# Machine-specific overrides (e.g., work email, git-secrets)
[include]
	path = ~/.gitconfig-local

# Directory-based overrides (uncomment and adjust for per-repo-directory config)
# [includeIf "gitdir:~/work/"]
#	path = ~/.gitconfig-work
